# Plantilla de variables de entorno. Copia este archivo a `.env.local` y
# rellena los valores reales. `.env.local` está en .gitignore y nunca se
# subirá al repo.
#
# Las variables prefijadas con VITE_ se exponen al código del frontend en
# tiempo de build. NO pongas aquí secretos del backend (service_role,
# DB password, etc.) — solo la URL pública del proyecto y la anon key.

# URL pública del proyecto Supabase. Sale de: Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key. Está pensada para vivir en el cliente; las RLS son lo
# que de verdad protege los datos. La service_role NUNCA va aquí.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
